<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KidsEducation.ViewModels.Pronunciation"
             xmlns:conv="clr-namespace:KidsEducation.Converters"
             x:Class="KidsEducation.Views.Pronunciation.PronunciationGamePage"
             x:DataType="vm:PronunciationGameViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource SurfaceSoft}">

    <ContentPage.Resources>
        <conv:InverseBoolConverter x:Key="InverseBool"/>
        <conv:BoolToFontAttrConverter x:Key="BoolToFontAttr"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Başlık ── -->
        <Border Grid.Row="0" StrokeThickness="0" Padding="20,50,20,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5148D4" Offset="0"/>
                    <GradientStop Color="#7C3AED" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="0">
                <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                        BackgroundColor="#24FFFFFF" Stroke="Transparent"
                        StrokeShape="RoundRectangle 12">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="←" FontSize="18" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
                <VerticalStackLayout Grid.Column="1" Spacing="6" HorizontalOptions="Center">
                    <Label Text="🎤 Telaffuz Oyunu"
                           FontSize="18" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center"/>
                    <ProgressBar Progress="{Binding Progress}"
                                 ProgressColor="White"
                                 BackgroundColor="#30FFFFFF"
                                 HeightRequest="6" WidthRequest="160"/>
                    <Label Text="{Binding ScoreText, StringFormat='✅ {0} doğru'}"
                           FontSize="11" TextColor="#CCFFFFFF"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <!-- Söyle butonu (sağ üst) -->
                <Border Grid.Column="2"
                        BackgroundColor="#24FFFFFF" Stroke="Transparent"
                        StrokeShape="RoundRectangle 12" Padding="10,8">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding SpeakWordCommand}"/>
                    </Border.GestureRecognizers>
                    <Label Text="🔊" FontSize="20" HorizontalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- ── Oyun Alanı ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16,20,16" Spacing="16">

                <!-- Yükleniyor -->
                <ActivityIndicator IsRunning="{Binding IsLoading}"
                                   IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource BrandPurple}"
                                   HorizontalOptions="Center" Margin="0,60,0,0"/>

                <!-- Bitiş ekranı -->
                <VerticalStackLayout IsVisible="{Binding IsFinished}"
                                     Spacing="16" HorizontalOptions="Center"
                                     Margin="0,40,0,0">
                    <Label Text="{Binding FeedbackEmoji}" FontSize="64" HorizontalOptions="Center"/>
                    <Label Text="Oyun Bitti!" FontSize="24" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
                    <Label Text="{Binding FeedbackText}"
                           FontSize="16" TextColor="{StaticResource TextMuted}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                    <Border BackgroundColor="{StaticResource BrandPurple}"
                            Stroke="Transparent" StrokeShape="RoundRectangle 18"
                            Padding="32,14" Margin="0,8,0,0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RestartCommand}"/>
                        </Border.GestureRecognizers>
                        <Label Text="🔄  Tekrar Oyna" FontSize="15" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Oyun içeriği -->
                <VerticalStackLayout IsVisible="{Binding IsFinished, Converter={StaticResource InverseBool}}"
                                     Spacing="16">

                    <!-- Mevcut kelime kartı -->
                    <Border IsVisible="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                            BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="#E7EBF5" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 24" Padding="20,20">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,4" Radius="12" Opacity="0.12"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12" HorizontalOptions="Center">
                            <!-- Resim -->
                            <Border WidthRequest="150" HeightRequest="150"
                                    BackgroundColor="#F0EEFF" Stroke="#DDD6FF"
                                    StrokeThickness="2" StrokeShape="RoundRectangle 24"
                                    HorizontalOptions="Center">
                                <Image Source="{Binding CurrentWord.ImagePath}"
                                       Aspect="AspectFit" Margin="12"/>
                            </Border>
                            <!-- Kelime adı -->
                            <Label Text="{Binding CurrentWord.NameTr}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   HorizontalOptions="Center"
                                   CharacterSpacing="2"/>
                            <!-- İlerleme: kaçıncı kelime -->
                            <Label Text="{Binding CurrentIndex, StringFormat='{0}'}"
                                   IsVisible="False"/>
                            <Label FontSize="12" TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding CurrentIndex}"/>
                                        <Span Text=" / "/>
                                        <Span Text="{Binding TotalWords}"/>
                                        <Span Text=". kelime"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Geri bildirim — doğru -->
                    <Border IsVisible="{Binding IsCorrect}"
                            BackgroundColor="#E6FFF5" Stroke="#86EFAC"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 18" Padding="16,14">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="{Binding FeedbackEmoji}" FontSize="24" VerticalOptions="Center"/>
                            <Label Text="{Binding FeedbackText}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#15803D"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Geri bildirim — yanlış -->
                    <Border IsVisible="{Binding IsWrong}"
                            BackgroundColor="#FFF1F2" Stroke="#FCA5A5"
                            StrokeThickness="1.5" StrokeShape="RoundRectangle 18" Padding="16,14">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Label Text="{Binding FeedbackEmoji}" FontSize="24" VerticalOptions="Center"/>
                                <Label Text="Tekrar dene!" FontSize="14" FontAttributes="Bold"
                                       TextColor="#B91C1C" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding FeedbackText}"
                                   FontSize="12" TextColor="#DC2626"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Duyduğum metin -->
                    <Border IsVisible="{Binding IsListening}"
                            BackgroundColor="#FFF8DC" Stroke="#FDE68A"
                            StrokeThickness="1" StrokeShape="RoundRectangle 14"
                            Padding="14,10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="👂 Duyduğum:" FontSize="11"
                                   TextColor="{StaticResource TextMuted}"/>
                            <Label Text="{Binding HeardText}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="#92400E"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- İzin uyarısı -->
                    <Border IsVisible="{Binding IsNoPermission}"
                            BackgroundColor="#FFF5F5" Stroke="#FCA5A5"
                            StrokeThickness="1" StrokeShape="RoundRectangle 14"
                            Padding="16,12">
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="🎙️ Mikrofon izni gerekiyor"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#B91C1C" HorizontalOptions="Center"/>
                            <Label Text="Ayarlar → Uygulama → İzinler → Mikrofon"
                                   FontSize="12" TextColor="#DC2626"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Kelime listesi (tüm) -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Kelimeler" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                        <CollectionView ItemsSource="{Binding Words}" HeightRequest="280">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:PronunciationWordCard">
                                    <Border BackgroundColor="{StaticResource SurfaceWhite}"
                                            Stroke="#E7EBF5" StrokeThickness="1"
                                            StrokeShape="RoundRectangle 14"
                                            Padding="6,8">
                                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                            <Image Source="{Binding ImagePath}"
                                                   Aspect="AspectFit"
                                                   WidthRequest="44" HeightRequest="44"/>
                                            <Label Text="{Binding NameTr}" FontSize="10"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   HorizontalOptions="Center"
                                                   LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding StatusEmoji}" FontSize="14"
                                                   HorizontalOptions="Center"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Mikrofon Butonu ── -->
        <Border Grid.Row="2"
                IsVisible="{Binding IsFinished, Converter={StaticResource InverseBool}}"
                BackgroundColor="{StaticResource SurfaceWhite}"
                Stroke="#E7EBF5" StrokeThickness="0.5"
                StrokeShape="RoundRectangle 0" Padding="20,16">
            <Border BackgroundColor="{Binding MicButtonColor}"
                    Stroke="Transparent" StrokeShape="RoundRectangle 20"
                    Padding="0,18">
                <Border.Shadow>
                    <Shadow Brush="#305148D4" Offset="0,4" Radius="12" Opacity="0.25"/>
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ListenCommand}"/>
                </Border.GestureRecognizers>
                <Label Text="{Binding MicButtonText}"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"/>
            </Border>
        </Border>

    </Grid>
</ContentPage>
