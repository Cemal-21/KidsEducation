<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KidsEducation.Views.Games.LearningModulesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Games"
    xmlns:models="clr-namespace:KidsEducation.Models"
    x:DataType="vm:LearningModulesViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="18,44,18,18"
              BackgroundColor="{StaticResource BrandPurple}">
            <controls:TappableBorder
                Grid.Column="0"
                Command="{Binding GoBackCommand}"
                WidthRequest="40" HeightRequest="40"
                BackgroundColor="#22FFFFFF" Stroke="#30FFFFFF"
                StrokeThickness="1" StrokeShape="RoundRectangle 13"
                VerticalOptions="Center">
                <Label Text="‹" FontSize="26" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-3,0,0" />
            </controls:TappableBorder>

            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center" Margin="12,0,0,0">
                <Label Text="Konular" FontSize="20" FontAttributes="Bold" TextColor="White" />
                <Label Text="Bir konu seç ve öğrenmeye başla" FontSize="12" TextColor="#BAFFFFFF" />
            </VerticalStackLayout>
        </Grid>

        <!-- Konu kartları -->
        <CollectionView Grid.Row="1"
                        x:Name="ModulesCollection"
                        ItemsSource="{Binding Categories}"
                        Margin="16,12,16,0">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2"
                                 HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Category">
                    <Grid HeightRequest="170">
                        <controls:TappableBorder
                            Command="{Binding Source={x:Reference ModulesCollection}, Path=BindingContext.OpenCategoryCommand}"
                            CommandParameter="{Binding .}"
                            BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="0">

                            <Grid RowDefinitions="*,52">
                                <!-- Resim alanı -->
                                <Border Grid.Row="0" Stroke="Transparent"
                                        BackgroundColor="{StaticResource AppBackground}"
                                        StrokeShape="RoundRectangle 20,20,0,0" Padding="0">
                                    <Grid>
                                        <Image Source="{Binding Image}" Aspect="AspectFill"
                                               HorizontalOptions="Fill" VerticalOptions="Fill"
                                               IsAnimationPlaying="False" />
                                        <!-- Kategori ikonu -->
                                        <Border WidthRequest="32" HeightRequest="32"
                                                BackgroundColor="#DDFFFFFF" Stroke="Transparent"
                                                StrokeShape="RoundRectangle 10"
                                                HorizontalOptions="End" VerticalOptions="Start"
                                                Margin="0,8,8,0">
                                            <Image Source="{Binding Image}"
                                                   WidthRequest="26" HeightRequest="26"
                                                   Aspect="AspectFit"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- Alt bilgi şeridi -->
                                <VerticalStackLayout Grid.Row="1" Spacing="5" Padding="10,8">
                                    <Label Text="{Binding NameTr}" FontSize="13" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation" />
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                        <ProgressBar Grid.Column="0"
                                                     Progress="{Binding ProgressNormalized}"
                                                     ProgressColor="{StaticResource BrandMint}"
                                                     BackgroundColor="{StaticResource BorderLight}"
                                                     HeightRequest="5" VerticalOptions="Center"/>
                                        <Label Grid.Column="1"
                                               Text="{Binding ProgressPercent, StringFormat='{0}%'}"
                                               FontSize="9" TextColor="{StaticResource TextMuted}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </Grid>
                        </controls:TappableBorder>

                        <!-- Kilit overlay -->
                        <Border BackgroundColor="#88FFFFFF" Stroke="Transparent"
                                StrokeShape="RoundRectangle 20" IsVisible="{Binding IsLocked}">
                            <Border BackgroundColor="White" Stroke="{StaticResource BorderLight}"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 12"
                                    Padding="10,6" HorizontalOptions="Center" VerticalOptions="Center">
                                <HorizontalStackLayout Spacing="5">
                                    <Image Source="ui_lock_3d.png" WidthRequest="16" HeightRequest="16" Aspect="AspectFit" VerticalOptions="Center" />
                                    <Label Text="Premium" FontSize="11" FontAttributes="Bold"
                                           TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.Footer>
                <BoxView HeightRequest="24" Opacity="0" />
            </CollectionView.Footer>
        </CollectionView>

    </Grid>
</ContentPage>
