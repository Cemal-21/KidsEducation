<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:KidsEducation.ViewModels.Report"
             xmlns:conv="clr-namespace:KidsEducation.Converters"
             x:Class="KidsEducation.Views.Report.ProgressReportPage"
             x:DataType="vm:ProgressReportViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource SurfaceSoft}">

    <ContentPage.Resources>
        <conv:BoolToFontAttrConverter x:Key="BoolToFontAttr"/>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ── Başlık ── -->
            <Border StrokeThickness="0" Padding="20,52,20,24">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#5148D4" Offset="0"/>
                        <GradientStop Color="#7C3AED" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="16">

                    <!-- Geri + paylaş -->
                    <Grid Grid.Row="0" ColumnDefinitions="44,*,Auto">
                        <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#24FFFFFF" Stroke="Transparent"
                                StrokeShape="RoundRectangle 12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="←" FontSize="18" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                            <Label Text="📊 Haftalık Rapor"
                                   FontSize="18" FontAttributes="Bold" TextColor="White"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding WeekRangeText}"
                                   FontSize="12" TextColor="#CCFFFFFF"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        <!-- Paylaş butonu -->
                        <Border Grid.Column="2"
                                BackgroundColor="#30FFFFFF" Stroke="#40FFFFFF"
                                StrokeThickness="1" StrokeShape="RoundRectangle 14"
                                Padding="14,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ShareReportCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="📤 Paylaş" FontSize="13" FontAttributes="Bold" TextColor="White"/>
                        </Border>
                    </Grid>

                    <!-- Profil özeti -->
                    <Border Grid.Row="1"
                            BackgroundColor="#20FFFFFF" Stroke="#30FFFFFF"
                            StrokeThickness="1" StrokeShape="RoundRectangle 20"
                            Padding="16,14">
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="14">
                            <!-- Avatar -->
                            <Border Grid.Column="0" WidthRequest="52" HeightRequest="52"
                                    BackgroundColor="#30FFFFFF" Stroke="#50FFFFFF"
                                    StrokeThickness="2" StrokeShape="RoundRectangle 18">
                                <Label Text="{Binding AvatarEmoji}" FontSize="28"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <!-- İsim + seri -->
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="{Binding ProfileName}"
                                       FontSize="17" FontAttributes="Bold" TextColor="White"/>
                                <Label Text="{Binding StreakText}"
                                       FontSize="12" TextColor="#DDFFFFFF"/>
                            </VerticalStackLayout>
                            <!-- Başarı rozeti -->
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="2">
                                <Label Text="{Binding AchievementBadge}" FontSize="28" HorizontalOptions="Center"/>
                                <Label Text="{Binding AchievementText}"
                                       FontSize="9" TextColor="#DDFFFFFF"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </Grid>
            </Border>

            <!-- ── İçerik ── -->
            <VerticalStackLayout Padding="16,16,16,32" Spacing="16">

                <!-- Haftalık sayaçlar -->
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                    <!-- Bu hafta yıldız -->
                    <Border Grid.Column="0"
                            BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="#E7EBF5" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="12,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="⭐" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding WeeklyStars}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="{StaticResource BrandPurple}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Bu Hafta" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Yıldız" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Tamamlanan ders -->
                    <Border Grid.Column="1"
                            BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="#E7EBF5" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="12,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="📚" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding WeeklyLessons}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#16A34A"
                                   HorizontalOptions="Center"/>
                            <Label Text="Bu Hafta" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Ders" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Toplam yıldız -->
                    <Border Grid.Column="2"
                            BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="#E7EBF5" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="12,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.1"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="🏆" FontSize="24" HorizontalOptions="Center"/>
                            <Label Text="{Binding TotalStars}"
                                   FontSize="22" FontAttributes="Bold"
                                   TextColor="#EA580C"
                                   HorizontalOptions="Center"/>
                            <Label Text="Toplam" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Yıldız" FontSize="10"
                                   TextColor="{StaticResource TextMuted}"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>

                <!-- Günlük Aktivite Grafiği -->
                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="#E7EBF5" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20" Padding="16,16">
                    <Border.Shadow>
                        <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.1"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="12">
                        <Label Text="📅 Bu Haftaki Aktivite"
                               FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"/>

                        <!-- Günlük çubuk grafik -->
                        <CollectionView ItemsSource="{Binding DayBars}"
                                        HeightRequest="90"
                                        ItemsLayout="HorizontalList">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:DayBarItem">
                                    <VerticalStackLayout WidthRequest="38" Spacing="4"
                                                         VerticalOptions="End"
                                                         HorizontalOptions="Center">
                                        <Label Text="{Binding MinutesText}"
                                               FontSize="8"
                                               TextColor="{Binding BarColor}"
                                               HorizontalOptions="Center"/>
                                        <Border BackgroundColor="{Binding BarColor}"
                                                HeightRequest="{Binding BarHeight}"
                                                WidthRequest="22"
                                                StrokeShape="RoundRectangle 6"
                                                Stroke="Transparent"
                                                HorizontalOptions="Center"
                                                VerticalOptions="End"/>
                                        <Label Text="{Binding DayLabel}"
                                               FontSize="10"
                                               FontAttributes="{Binding IsToday, Converter={StaticResource BoolToFontAttr}}"
                                               TextColor="{Binding DayLabelColor}"
                                               HorizontalOptions="Center"/>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        <Label Text="(Günlük ortalama: her ders ≈5 dk)"
                               FontSize="10" TextColor="{StaticResource TextMuted}"
                               HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- En İyi Kategoriler -->
                <VerticalStackLayout Spacing="8" IsVisible="{Binding HasTopCategories}">
                    <Label Text="🏅 Bu Haftanın En İyi Konuları"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"/>

                    <CollectionView ItemsSource="{Binding TopCategories}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:CategoryHighlight">
                                <Border Margin="0,0,0,8"
                                        BackgroundColor="{StaticResource SurfaceWhite}"
                                        Stroke="#E7EBF5" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16" Padding="14,12">
                                    <Border.Shadow>
                                        <Shadow Brush="#10000000" Offset="0,2" Radius="6" Opacity="0.08"/>
                                    </Border.Shadow>
                                    <Grid ColumnDefinitions="44,*,Auto" ColumnSpacing="10">
                                        <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                                                BackgroundColor="#F0EEFF" Stroke="Transparent"
                                                StrokeShape="RoundRectangle 13">
                                            <Label Text="{Binding Emoji}" FontSize="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding NameTr}"
                                               FontSize="14" FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}"
                                               VerticalOptions="Center"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding StarsText}"
                                               FontSize="16"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Büyük paylaş butonu -->
                <Border BackgroundColor="{StaticResource BrandPurple}"
                        Stroke="Transparent" StrokeShape="RoundRectangle 20"
                        Padding="0,16" Margin="0,8,0,0">
                    <Border.Shadow>
                        <Shadow Brush="#305148D4" Offset="0,4" Radius="12" Opacity="0.3"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ShareReportCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                        <Label Text="📤" FontSize="20" VerticalOptions="Center"/>
                        <Label Text="Raporu Paylaş" FontSize="16" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
