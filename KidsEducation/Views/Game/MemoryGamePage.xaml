<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KidsEducation.Views.Game.MemoryGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:converters="clr-namespace:KidsEducation.Converters"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PlaygroundBackground}">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Padding="18,46,18,14" ColumnSpacing="12">
            <controls:TappableBorder
                Grid.Column="0"
                Command="{Binding GoBackCommand}"
                WidthRequest="46"
                HeightRequest="46"
                BackgroundColor="{StaticResource SurfaceWhite}"
                Stroke="#FFE2C1"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">
                <Label Text="‹" FontSize="32" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-4,0,0" />
            </controls:TappableBorder>

            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Grid.Column="0" Text="Hafıza Oyunu 🧠" FontSize="12" TextColor="{StaticResource TextMuted}" FontAttributes="Bold" />
                    <Label Grid.Column="1" Text="{Binding Progress, StringFormat='{0:P0}'}" FontSize="12" TextColor="{StaticResource BrandPurple}" FontAttributes="Bold" />
                </Grid>
                <ProgressBar
                    Progress="{Binding Progress}"
                    ProgressColor="{StaticResource BrandMint}"
                    BackgroundColor="#FFE9CC"
                    HeightRequest="9" />
            </VerticalStackLayout>

            <Border
                Grid.Column="2"
                BackgroundColor="{StaticResource SurfaceWhite}"
                Stroke="#FFE2C1"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 15"
                Padding="10,7"
                VerticalOptions="Center">
                <Label FontSize="14" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding Moves}" />
                            <Span Text=" hamle" TextColor="{StaticResource TextMuted}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Border>
        </Grid>

        <ScrollView Grid.Row="1">
            <Grid Padding="16,8,16,24">
                <CollectionView
                    ItemsSource="{Binding Cards}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                    </CollectionView.ItemsLayout>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MemoryCard">
                            <controls:TappableBorder
                                Command="{Binding BindingContext.FlipCardCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                                CommandParameter="{Binding .}"
                                HeightRequest="100"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 18">

                                <Grid>
                                    <Border
                                        BackgroundColor="{StaticResource BrandPurple}"
                                        Stroke="Transparent"
                                        StrokeShape="RoundRectangle 18"
                                        IsVisible="{Binding IsFlipped, Converter={StaticResource InverseBoolConverter}}">
                                        <Label
                                            Text="❓"
                                            FontSize="36"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <Border
                                        BackgroundColor="{StaticResource SurfaceWhite}"
                                        Stroke="#FFE2C1"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 18"
                                        IsVisible="{Binding IsFlipped}"
                                        Padding="8">
                                        <Image
                                            Source="{Binding ImagePath}"
                                            Aspect="AspectFit"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>

                                    <Border
                                        BackgroundColor="#E0FFF4"
                                        Stroke="{StaticResource BrandMint}"
                                        StrokeThickness="2"
                                        StrokeShape="RoundRectangle 18"
                                        IsVisible="{Binding IsMatched}"
                                        Opacity="0.85">
                                        <Label
                                            Text="✓"
                                            FontSize="32"
                                            FontAttributes="Bold"
                                            TextColor="{StaticResource BrandMint}"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center" />
                                    </Border>
                                </Grid>
                            </controls:TappableBorder>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </ScrollView>

    </Grid>
</ContentPage>