<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Game.SortingGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Game"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ── -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,24,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EA580C" Offset="0"/>
                    <GradientStop Color="#F97316" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Padding="16,44,16,16" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                            BackgroundColor="#28FFFFFF" Stroke="#40FFFFFF"
                            StrokeShape="RoundRectangle 12">
                        <Label Text="←" FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <Label Grid.Column="1" Text="📊 Kavram Sırala"
                           FontSize="17" FontAttributes="Bold" TextColor="White"
                           VerticalOptions="Center"/>
                    <Border Grid.Column="2" BackgroundColor="#28FFFFFF" Stroke="#40FFFFFF"
                            StrokeShape="RoundRectangle 12" Padding="10,6">
                        <Label Text="{Binding CurrentRound, StringFormat='Tur {0}/5'}"
                               FontSize="13" FontAttributes="Bold" TextColor="White"/>
                    </Border>
                </Grid>
                <ProgressBar Grid.Row="1" Progress="{Binding Progress}"
                             ProgressColor="White" BackgroundColor="#40FFFFFF"
                             HeightRequest="6"/>
                <Label Grid.Row="2" Text="{Binding TaskLabel}"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"/>
            </Grid>
        </Border>

        <!-- ── Body ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16,20,16,24" Spacing="20">

                <!-- Answer slots -->
                <Border BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20" Padding="12,14">
                    <Border.Shadow>
                        <Shadow Brush="#10000000" Offset="0,4" Radius="12" Opacity="0.12"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Sıraladıkların:" FontSize="12"
                               TextColor="{StaticResource TextMuted}" FontAttributes="Bold"/>
                        <CollectionView ItemsSource="{Binding PlacedCards}" HeightRequest="90"
                                        SelectionMode="None">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8"/>
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="vm:SortingCard">
                                    <Border WidthRequest="70" HeightRequest="82"
                                            StrokeShape="RoundRectangle 14"
                                            BackgroundColor="{Binding BackgroundColor}"
                                            Stroke="{Binding BorderColor}"
                                            StrokeThickness="2">
                                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="4">
                                            <Image Source="{Binding ImagePath}"
                                                   WidthRequest="40" HeightRequest="40" Aspect="AspectFit"/>
                                            <Label Text="{Binding NameTr}" FontSize="9" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   HorizontalOptions="Center"
                                                   HorizontalTextAlignment="Center"/>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

                <!-- Instructions -->
                <Label Text="Aşağıdaki kartlara doğru sırayla dokun 👇"
                       FontSize="13" TextColor="{StaticResource TextMuted}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <!-- Shuffled cards -->
                <CollectionView ItemsSource="{Binding Cards}"
                                SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="3"
                                         HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="vm:SortingCard">
                            <Border HeightRequest="96"
                                    StrokeShape="RoundRectangle 18"
                                    BackgroundColor="{Binding BackgroundColor}"
                                    Stroke="{Binding BorderColor}"
                                    StrokeThickness="2">
                                <Border.Shadow>
                                    <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.1"/>
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.TapCardCommand}"
                                        CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                    <Image Source="{Binding ImagePath}"
                                           WidthRequest="52" HeightRequest="52" Aspect="AspectFit"/>
                                    <Label Text="{Binding NameTr}" FontSize="12" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ── Feedback overlay ── -->
        <Border Grid.RowSpan="2" IsVisible="{Binding ShowFeedback}"
                BackgroundColor="#88000000" StrokeShape="RoundRectangle 0">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                <Label Text="{Binding FeedbackEmoji}" FontSize="80" HorizontalOptions="Center"/>
                <Label Text="{Binding FeedbackText}" FontSize="22" FontAttributes="Bold"
                       TextColor="White" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</views:AnimatedPage>
