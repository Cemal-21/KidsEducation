<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KidsEducation.Views.Game.FindMarkGamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Game"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F0F2FA">

    <ContentPage.Resources>
        <Color x:Key="TextPrimary">#172033</Color>
        <Color x:Key="TextMuted">#6B7280</Color>
        <Color x:Key="SurfaceWhite">#FFFFFF</Color>
        <Color x:Key="BorderLight">#E8E8F0</Color>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- HEADER -->
        <Border Grid.Row="0" BackgroundColor="#FFFFFF" Stroke="{StaticResource BorderLight}"
                StrokeThickness="0.5" StrokeShape="RoundRectangle 0,0,24,24" Padding="16,44,16,16">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <Border Grid.Column="0" WidthRequest="40" HeightRequest="40"
                        BackgroundColor="#F1EEFF" Stroke="#DDD6FF" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="←" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"
                           TextColor="#6C62F5" />
                </Border>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="2">
                    <Label Text="Bul &amp; İşaretle" FontSize="18" FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                    <ProgressBar Progress="{Binding ProgressPercent}" ProgressColor="#6C62F5"
                                 BackgroundColor="#EDE8FF" HeightRequest="6" WidthRequest="160" />
                </VerticalStackLayout>

                <Border Grid.Column="2" BackgroundColor="#F1EEFF" Stroke="#DDD6FF"
                        StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="10,6">
                    <Label FontSize="13" FontAttributes="Bold" TextColor="#6C62F5">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding CurrentRound}" />
                                <Span Text="/" />
                                <Span Text="{Binding TotalRounds}" />
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </Border>
            </Grid>
        </Border>

        <!-- SORU -->
        <Border Grid.Row="1" BackgroundColor="#5148D4" Margin="16,12,16,0"
                StrokeShape="RoundRectangle 20" Padding="20,16">
            <Border.Shadow>
                <Shadow Brush="#335148D4" Offset="0,6" Radius="20" Opacity="0.35" />
            </Border.Shadow>
            <Label Text="{Binding QuestionText}"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </Border>

        <!-- 6 SEÇENEKLİ GRID -->
        <Grid Grid.Row="2" Padding="16,12,16,24">
            <CollectionView ItemsSource="{Binding Options}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:FindMarkOption">
                        <Border
                            BackgroundColor="{Binding BackgroundColor}"
                            Stroke="{Binding BorderColor}"
                            StrokeThickness="2.5"
                            StrokeShape="RoundRectangle 18"
                            Padding="8"
                            HeightRequest="110">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.SelectOptionCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Image Source="{Binding ImagePath}" Aspect="AspectFit"
                                   HorizontalOptions="Fill" VerticalOptions="Fill" />
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- GERİ BİLDİRİM -->
            <Border IsVisible="{Binding ShowFeedback}"
                    BackgroundColor="#CC000000" StrokeShape="RoundRectangle 20"
                    Padding="28,20" HorizontalOptions="Center" VerticalOptions="Center">
                <Label Text="{Binding FeedbackEmoji}" FontSize="70"
                       HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>
