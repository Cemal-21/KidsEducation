<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Game.MemoryGameV2Page"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Game"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- ── Header ── -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,24,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5148D4" Offset="0"/>
                    <GradientStop Color="#3A86FF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Padding="16,44,16,16" RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                    <Border Grid.Column="0" WidthRequest="38" HeightRequest="38"
                            BackgroundColor="#28FFFFFF" Stroke="#40FFFFFF"
                            StrokeShape="RoundRectangle 12">
                        <Label Text="←" FontSize="20" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="🃏 Hafıza Kartları" FontSize="17" FontAttributes="Bold" TextColor="White"/>
                        <Label Text="{Binding ProgressText}" FontSize="11" TextColor="#DDFFFFFF"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="2" BackgroundColor="#28FFFFFF" Stroke="#40FFFFFF"
                            StrokeShape="RoundRectangle 12" Padding="10,6">
                        <Label Text="{Binding Moves, StringFormat='⚡ {0}'}" FontSize="13"
                               FontAttributes="Bold" TextColor="White"/>
                    </Border>
                </Grid>
                <ProgressBar Grid.Row="1" Progress="{Binding Progress}"
                             ProgressColor="White" BackgroundColor="#40FFFFFF"
                             HeightRequest="6"/>
                <Label Grid.Row="2" FontSize="12" TextColor="#DDFFFFFF"
                       HorizontalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Görseli adıyla eşleştir · "/>
                            <Span Text="{Binding MatchedPairs}" FontAttributes="Bold"/>
                            <Span Text="/"/>
                            <Span Text="{Binding TotalPairs}"/>
                            <Span Text=" çift bulundu"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
        </Border>

        <!-- ── Cards Grid ── -->
        <ScrollView Grid.Row="1">
            <CollectionView ItemsSource="{Binding Cards}"
                            Margin="12,12,12,16"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="3" HorizontalItemSpacing="8" VerticalItemSpacing="8"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:MemoryV2Card">
                        <Border HeightRequest="100"
                                StrokeShape="RoundRectangle 16"
                                BackgroundColor="{Binding BackgroundColor}"
                                Stroke="{Binding BorderColor}"
                                StrokeThickness="2">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.FlipCardCommand}"
                                    CommandParameter="{Binding .}"/>
                            </Border.GestureRecognizers>

                            <Grid>
                                <!-- Back face (not flipped) -->
                                <Border IsVisible="{Binding IsFlipped, Converter={StaticResource InverseBool}}"
                                        BackgroundColor="#EEF2FF"
                                        StrokeShape="RoundRectangle 14" Stroke="Transparent">
                                    <Label Text="❓" FontSize="32"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>

                                <!-- Front face — Image card -->
                                <VerticalStackLayout IsVisible="{Binding IsFlipped}"
                                                     HorizontalOptions="Center" VerticalOptions="Center"
                                                     Spacing="4">
                                    <Image Source="{Binding ImagePath}"
                                           IsVisible="{Binding IsImageCard}"
                                           WidthRequest="56" HeightRequest="56"
                                           Aspect="AspectFit"/>
                                    <!-- Name card -->
                                    <Label Text="{Binding NameTr}"
                                           IsVisible="{Binding IsNameCard}"
                                           FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource BrandPurple}"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           Padding="4,0"/>
                                    <!-- Matched checkmark -->
                                    <Label Text="✓" FontSize="11" FontAttributes="Bold"
                                           TextColor="#28B87A" HorizontalOptions="Center"
                                           IsVisible="{Binding IsMatched}"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </ScrollView>

        <!-- ── Feedback overlay ── -->
        <Border Grid.RowSpan="2" IsVisible="{Binding ShowFeedback}"
                BackgroundColor="#88000000" StrokeShape="RoundRectangle 0">
            <Label Text="{Binding FeedbackEmoji}" FontSize="96"
                   HorizontalOptions="Center" VerticalOptions="Center"/>
        </Border>

    </Grid>
</views:AnimatedPage>
