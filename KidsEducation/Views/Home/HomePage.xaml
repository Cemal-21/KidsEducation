<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Home.HomePage"
    x:Name="HomeRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:converters="clr-namespace:KidsEducation.Converters"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <converters:EmojiIconConverter x:Key="EmojiIconConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ══ HEADER ══ -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,32,32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#4338CA" Offset="0.0" />
                    <GradientStop Color="#7C3AED" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid Padding="20,44,20,18" RowDefinitions="Auto,Auto" RowSpacing="14">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                        <Label Text="{Binding TodayDateText}" FontSize="11" TextColor="#AAFFFFFF" />
                        <Label Text="{Binding ActiveProfile.Name, StringFormat='Merhaba, {0}!'}"
                               FontSize="22" FontAttributes="Bold" TextColor="White"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <controls:TappableBorder Grid.Column="1"
                        Command="{Binding GoToProfileSelectionCommand}"
                        WidthRequest="50" HeightRequest="50"
                        BackgroundColor="#25FFFFFF" Stroke="#40FFFFFF"
                        StrokeThickness="1.5" StrokeShape="RoundRectangle 18"
                        VerticalOptions="Center">
                        <Grid>
                            <Image Source="{Binding ActiveProfile.AvatarEmoji, Converter={StaticResource EmojiIconConverter}}"
                                   WidthRequest="38" HeightRequest="38"
                                   Aspect="AspectFit"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                            <Image Source="ui_crown_3d.png"
                                   WidthRequest="18" HeightRequest="18"
                                   HorizontalOptions="End" VerticalOptions="Start"
                                   TranslationX="5" TranslationY="-5" />
                        </Grid>
                    </controls:TappableBorder>
                </Grid>
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    <Border Grid.Column="0" Style="{StaticResource HeroStatPill}" Padding="10,8">
                        <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Image Source="ui_streak_3d.png" WidthRequest="18" HeightRequest="18" Aspect="AspectFit"/>
                                <Label Text="{Binding ActiveProfile.StreakDays}"
                                       FontSize="15" FontAttributes="Bold" TextColor="#FFD97D" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="gün seri" FontSize="8" TextColor="#BBFFFFFF" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource HeroStatPill}" Padding="10,8">
                        <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Image Source="ui_star_3d.png" WidthRequest="18" HeightRequest="18" Aspect="AspectFit"/>
                                <Label Text="{Binding ActiveProfile.TotalStars}"
                                       FontSize="15" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="yıldız" FontSize="8" TextColor="#BBFFFFFF" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource HeroStatPill}" Padding="10,8">
                        <VerticalStackLayout Spacing="1" HorizontalOptions="Center">
                            <HorizontalStackLayout Spacing="4" HorizontalOptions="Center">
                                <Image Source="ui_goal_3d.png" WidthRequest="18" HeightRequest="18" Aspect="AspectFit"/>
                                <Label Text="{Binding DailyGoal.CompletionText}"
                                       FontSize="15" FontAttributes="Bold" TextColor="White" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="bugün" FontSize="8" TextColor="#BBFFFFFF" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ CONTENT ══ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="0,0,0,28" Spacing="0">

                <!-- Offline Banner -->
                <Border IsVisible="{Binding IsOffline}"
                        Stroke="#94A3B8" StrokeThickness="1"
                        StrokeShape="RoundRectangle 14" Padding="14,10"
                        Margin="16,12,16,0" BackgroundColor="#F1F5F9">
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Image Source="ui_offline_3d.png" WidthRequest="24" HeightRequest="24" Aspect="AspectFit"/>
                        <Label Text="Cevrimdisi mod - tum icerikler cihazinda mevcut"
                               FontSize="12" TextColor="#475569"
                               VerticalOptions="Center" HorizontalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- ── SLIDER ── -->
                <CarouselView x:Name="FeaturedCarousel"
                              ItemsSource="{Binding SliderCards}"
                              HeightRequest="160"
                              Loop="True"
                              IndicatorView="CarouselIndicator"
                              Margin="0,16,0,0">
                    <CarouselView.ItemTemplate>
                        <DataTemplate x:DataType="models:HomeSliderCard">
                            <Grid Padding="16,4">
                                <Border StrokeShape="RoundRectangle 24" Stroke="Transparent" Padding="20,16">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="{Binding GradientFrom}" Offset="0"/>
                                            <GradientStop Color="{Binding GradientTo}" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Shadow>
                                        <Shadow Brush="#405148D4" Offset="0,6" Radius="18" Opacity="0.35"/>
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={x:Reference HomeRoot}, Path=BindingContext.SliderTapCommand}"
                                            CommandParameter="{Binding .}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*">
                                        <Image Grid.Column="0" Source="{Binding IconSource}"
                                               WidthRequest="72" HeightRequest="72"
                                               Aspect="AspectFit"
                                               VerticalOptions="Center" Margin="0,0,16,0"/>
                                        <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontSize="10" FontAttributes="Bold"
                                                   TextColor="#CCffffff" CharacterSpacing="1.5"
                                                   TextTransform="Uppercase"/>
                                            <Label Text="{Binding Subtitle}" FontSize="20" FontAttributes="Bold"
                                                   TextColor="White" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Detail}" FontSize="13" TextColor="#DDFFFFFF"/>
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CarouselView.ItemTemplate>
                    <CarouselView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="0" SnapPointsType="MandatorySingle"/>
                    </CarouselView.ItemsLayout>
                </CarouselView>

                <IndicatorView x:Name="CarouselIndicator"
                               IndicatorColor="#20000000"
                               SelectedIndicatorColor="#5148D4"
                               IndicatorSize="7"
                               HorizontalOptions="Center"
                               Margin="0,6,0,20"/>

                <!-- ── KEŞFET GRID ── -->
                <VerticalStackLayout Padding="16,0,16,0" Spacing="12">

                    <Label Text="KEŞFET" FontSize="11" FontAttributes="Bold"
                           TextColor="#9CA3AF" CharacterSpacing="2" Margin="2,0,0,2"/>

                    <!-- Oyunlar — geniş hero kart -->
                    <controls:TappableBorder Command="{Binding GoToGamesCommand}"
                                             StrokeShape="RoundRectangle 20"
                                             BackgroundColor="White"
                                             Stroke="#E5E7EB" StrokeThickness="1"
                                             HeightRequest="90">
                        <controls:TappableBorder.Shadow>
                            <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                        </controls:TappableBorder.Shadow>
                        <Grid ColumnDefinitions="88,*,Auto" ColumnSpacing="0">
                            <!-- Görsel alanı (ilerde kapak görseli buraya) -->
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 20,0,0,20"
                                    BackgroundColor="#EEF0FF" Stroke="Transparent">
                                <Image Source="ui_games_3d.png"
                                       WidthRequest="62" HeightRequest="62"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4"
                                                 VerticalOptions="Center" Padding="16,0,12,0">
                                <Label Text="Oyunlar" FontSize="16" FontAttributes="Bold"
                                       TextColor="#1F2937"/>
                                <Label Text="11 farklı oyun seni bekliyor"
                                       FontSize="12" TextColor="#9CA3AF"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="#D1D5DB" VerticalOptions="Center" Margin="0,0,16,0"/>
                        </Grid>
                    </controls:TappableBorder>

                    <!-- Masallar + Şarkılar -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <controls:TappableBorder Grid.Column="0"
                                                 Command="{Binding GoToTalesCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <!-- Görsel alanı -->
                                <Border HeightRequest="90" BackgroundColor="#FFF0F5"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_tales_3d.png"
                                           WidthRequest="62" HeightRequest="62"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <!-- Bilgi alanı -->
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Masallar" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="6 klasik masal" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>

                        <controls:TappableBorder Grid.Column="1"
                                                 Command="{Binding GoToSongsCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <Border HeightRequest="90" BackgroundColor="#FFFBF0"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_songs_3d.png"
                                           WidthRequest="62" HeightRequest="62"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Şarkılar" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="Ritim &amp; müzik" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>
                    </Grid>

                    <!-- Konular + Macera -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <controls:TappableBorder Grid.Column="0"
                                                 Command="{Binding GoToLearningModulesCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <Border HeightRequest="90" BackgroundColor="#F0FDF4"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_learning_3d.png"
                                           WidthRequest="62" HeightRequest="62"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Konular" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="Tüm kategoriler" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>

                        <controls:TappableBorder Grid.Column="1"
                                                 Command="{Binding GoToAdventureMapCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <Border HeightRequest="90" BackgroundColor="#EFF6FF"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_adventure_3d.png"
                                           WidthRequest="62" HeightRequest="62"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Macera" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="Haritada ilerle" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>
                    </Grid>

                    <!-- Hazinem + Sıralama -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <controls:TappableBorder Grid.Column="0"
                                                 Command="{Binding GoToVocabularyCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <Border HeightRequest="80" BackgroundColor="#FAF5FF"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_vocabulary_3d.png"
                                           WidthRequest="54" HeightRequest="54"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Hazinem" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="Kelimelerim" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>

                        <controls:TappableBorder Grid.Column="1"
                                                 Command="{Binding GoToLeaderboardCommand}"
                                                 StrokeShape="RoundRectangle 20"
                                                 BackgroundColor="White"
                                                 Stroke="#E5E7EB" StrokeThickness="1">
                            <controls:TappableBorder.Shadow>
                                <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                            </controls:TappableBorder.Shadow>
                            <VerticalStackLayout Spacing="0">
                                <Border HeightRequest="80" BackgroundColor="#FFFBEB"
                                        Stroke="Transparent" StrokeShape="RoundRectangle 20,20,0,0">
                                    <Image Source="ui_leaderboard_3d.png"
                                           WidthRequest="54" HeightRequest="54"
                                           Aspect="AspectFit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Padding="12,10,12,12" Spacing="3">
                                    <Label Text="Sıralama" FontSize="14" FontAttributes="Bold"
                                           TextColor="#1F2937"/>
                                    <Label Text="Aile yarışması" FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </controls:TappableBorder>
                    </Grid>

                    <!-- Ebeveyn Paneli -->
                    <controls:TappableBorder Command="{Binding GoToParentalCommand}"
                                             StrokeShape="RoundRectangle 20"
                                             BackgroundColor="White"
                                             Stroke="#E5E7EB" StrokeThickness="1"
                                             HeightRequest="68">
                        <controls:TappableBorder.Shadow>
                            <Shadow Brush="#12000000" Offset="0,4" Radius="12" Opacity="0.15"/>
                        </controls:TappableBorder.Shadow>
                        <Grid ColumnDefinitions="68,*,Auto" ColumnSpacing="0">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 20,0,0,20"
                                    BackgroundColor="#F5F3FF" Stroke="Transparent">
                                <Image Source="ui_parental_3d.png"
                                       WidthRequest="46" HeightRequest="46"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3"
                                                 VerticalOptions="Center" Padding="16,0,12,0">
                                <Label Text="Ebeveyn Paneli" FontSize="15" FontAttributes="Bold"
                                       TextColor="#1F2937"/>
                                <Label Text="Ayarlar, rapor &amp; yedekleme"
                                       FontSize="11" TextColor="#9CA3AF"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="›" FontSize="22"
                                   TextColor="#D1D5DB" VerticalOptions="Center" Margin="0,0,16,0"/>
                        </Grid>
                    </controls:TappableBorder>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ══ BOTTOM TAB BAR ══ -->
        <controls:BottomTabBar Grid.Row="2" IsHomeActive="True" />

        <!-- ══ ASISTAN ══ -->
        <controls:AssistantBubble Grid.Row="0" Grid.RowSpan="2" PageKey="home"
                                   HorizontalOptions="Fill" VerticalOptions="Fill" ZIndex="10" />
    </Grid>
</views:AnimatedPage>
