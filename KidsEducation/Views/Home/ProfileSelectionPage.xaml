<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KidsEducation.Views.Home.ProfileSelectionPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Home"
    xmlns:conv="clr-namespace:KidsEducation.Converters"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F0F4FF">

    <ContentPage.Resources>
        <conv:AgeGroupToColorConverter x:Key="ToddlerColor" TargetGroup="Toddler"/>
        <conv:AgeGroupToColorConverter x:Key="ExplorerColor" TargetGroup="Explorer"/>
        <conv:AgeGroupToColorConverter x:Key="AdventurerColor" TargetGroup="Adventurer"/>
        <conv:AgeGroupToStrokeConverter x:Key="ToddlerStroke" TargetGroup="Toddler"/>
        <conv:AgeGroupToStrokeConverter x:Key="ExplorerStroke" TargetGroup="Explorer"/>
        <conv:AgeGroupToStrokeConverter x:Key="AdventurerStroke" TargetGroup="Adventurer"/>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Üst dekoratif alan -->
            <Grid HeightRequest="220" BackgroundColor="#6C63FF">
                <Ellipse
                    Fill="#5B52EE"
                    WidthRequest="300"
                    HeightRequest="300"
                    HorizontalOptions="End"
                    VerticalOptions="Start"
                    TranslationX="80"
                    TranslationY="-80"/>
                <Ellipse
                    Fill="#7B72FF"
                    WidthRequest="200"
                    HeightRequest="200"
                    HorizontalOptions="Start"
                    VerticalOptions="End"
                    TranslationX="-60"
                    TranslationY="60"/>
                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center"
                    Spacing="6"
                    Margin="0,30,0,0">
                    <Label
                        Text="👋"
                        FontSize="52"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="Merhaba!"
                        FontSize="34"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalOptions="Center"/>
                    <Label
                        Text="Kim oynuyor?"
                        FontSize="16"
                        TextColor="#FFFFFF99"
                        HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>

            <!-- İçerik -->
            <VerticalStackLayout Padding="20,20,20,40" Spacing="16" BackgroundColor="#F0F4FF">

                <!-- Mevcut profiller -->
                <CollectionView ItemsSource="{Binding Profiles}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 20"
                                Stroke="Transparent"
                                Margin="0,4"
                                Padding="16">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ProfileSelectionViewModel}}, Path=SelectProfileCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border
                                        Grid.Column="0"
                                        BackgroundColor="#FFD93D"
                                        StrokeShape="RoundRectangle 28"
                                        Stroke="Transparent"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        Padding="0">
                                        <Label
                                            Text="{Binding AvatarEmoji}"
                                            FontSize="28"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>
                                    </Border>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Margin="14,0,0,0"
                                        VerticalOptions="Center">
                                        <Label
                                            Text="{Binding Name}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#2D2D2D"/>
                                        <Label
                                            Text="{Binding AgeGroupName}"
                                            FontSize="13"
                                            TextColor="#888888"/>
                                    </VerticalStackLayout>
                                    <Label
                                        Grid.Column="2"
                                        Text="→"
                                        FontSize="22"
                                        TextColor="#6C63FF"
                                        VerticalOptions="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <!-- Ayraç -->
                <Label
                    Text="— ya da yeni profil oluştur —"
                    FontSize="13"
                    TextColor="#AAAAAA"
                    HorizontalOptions="Center"
                    Margin="0,4"/>

                <!-- Yeni profil formu -->
                <Border
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 24"
                    Stroke="Transparent"
                    Padding="20">
                    <VerticalStackLayout Spacing="16">

                        <!-- İsim -->
                        <Border
                            BackgroundColor="#F5F5F5"
                            StrokeShape="RoundRectangle 14"
                            Stroke="Transparent"
                            Padding="16,0">
                            <Entry
                                Placeholder="Adın ne? 😊"
                                Text="{Binding NewProfileName}"
                                FontSize="16"
                                TextColor="#2D2D2D"
                                PlaceholderColor="#AAAAAA"
                                BackgroundColor="Transparent"
                                HeightRequest="52"/>
                        </Border>

                        <!-- Yaş grubu başlığı -->
                        <Label
                            Text="Yaş grubunu seç:"
                            FontSize="14"
                            FontAttributes="Bold"
                            TextColor="#555555"/>

                        <!-- Yaş kartları -->
                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                            <Border
                                Grid.Column="0"
                                BackgroundColor="{Binding SelectedAgeGroup, Converter={StaticResource ToddlerColor}}"
                                StrokeShape="RoundRectangle 16"
                                Stroke="{Binding SelectedAgeGroup, Converter={StaticResource ToddlerStroke}}"
                                StrokeThickness="2"
                                Padding="8,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding SelectAgeGroupCommand}"
                                        CommandParameter="1"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="🐰" FontSize="32" HorizontalOptions="Center"/>
                                    <Label Text="Minikler" FontSize="13" FontAttributes="Bold" TextColor="#2D2D2D" HorizontalOptions="Center"/>
                                    <Label Text="3-5 yaş" FontSize="11" TextColor="#888888" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="1"
                                BackgroundColor="{Binding SelectedAgeGroup, Converter={StaticResource ExplorerColor}}"
                                StrokeShape="RoundRectangle 16"
                                Stroke="{Binding SelectedAgeGroup, Converter={StaticResource ExplorerStroke}}"
                                StrokeThickness="2"
                                Padding="8,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding SelectAgeGroupCommand}"
                                        CommandParameter="2"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="🦊" FontSize="32" HorizontalOptions="Center"/>
                                    <Label Text="Keşifçiler" FontSize="13" FontAttributes="Bold" TextColor="#2D2D2D" HorizontalOptions="Center"/>
                                    <Label Text="5-7 yaş" FontSize="11" TextColor="#888888" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>

                            <Border
                                Grid.Column="2"
                                BackgroundColor="{Binding SelectedAgeGroup, Converter={StaticResource AdventurerColor}}"
                                StrokeShape="RoundRectangle 16"
                                Stroke="{Binding SelectedAgeGroup, Converter={StaticResource AdventurerStroke}}"
                                StrokeThickness="2"
                                Padding="8,12">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding SelectAgeGroupCommand}"
                                        CommandParameter="3"/>
                                </Border.GestureRecognizers>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="🦉" FontSize="32" HorizontalOptions="Center"/>
                                    <Label Text="Kaşifler" FontSize="13" FontAttributes="Bold" TextColor="#2D2D2D" HorizontalOptions="Center"/>
                                    <Label Text="7-9 yaş" FontSize="11" TextColor="#888888" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>

                        <!-- Oluştur butonu -->
                        <Button
                            Text="Profil Oluştur 🚀"
                            Command="{Binding CreateProfileCommand}"
                            BackgroundColor="#6C63FF"
                            TextColor="White"
                            FontSize="17"
                            FontAttributes="Bold"
                            CornerRadius="16"
                            HeightRequest="56"/>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>