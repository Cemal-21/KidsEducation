<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="KidsEducation.Views.Home.DailyGoalPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Home"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    x:DataType="vm:DailyGoalViewModel"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="18,44,18,18"
              BackgroundColor="{StaticResource BrandPurple}">
            <controls:TappableBorder Grid.Column="0" Command="{Binding GoBackCommand}"
                WidthRequest="40" HeightRequest="40" BackgroundColor="#22FFFFFF"
                Stroke="#30FFFFFF" StrokeThickness="1" StrokeShape="RoundRectangle 13"
                VerticalOptions="Center">
                <Label Text="‹" FontSize="26" TextColor="White"
                       HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-3,0,0"/>
            </controls:TappableBorder>
            <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center" Margin="12,0,0,0">
                <Label Text="Günlük Görevler" FontSize="20" FontAttributes="Bold" TextColor="White"/>
                <Label Text="Her gün öğren, serini koru!" FontSize="12" TextColor="#BAFFFFFF"/>
            </VerticalStackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,20" Spacing="16">

                <ActivityIndicator IsRunning="{Binding IsLoading}" IsVisible="{Binding IsLoading}"
                                   Color="{StaticResource BrandPurple}" HorizontalOptions="Center"/>

                <VerticalStackLayout IsVisible="{Binding IsLoading, Converter={StaticResource InvertedBoolConverter}}"
                                     Spacing="16">

                    <!-- Streak Kartı -->
                    <Border BackgroundColor="{StaticResource BrandPurple}" Stroke="Transparent"
                            StrokeShape="RoundRectangle 24" Padding="24,20">
                        <Border.Shadow>
                            <Shadow Brush="#305148D4" Offset="0,6" Radius="16" Opacity="0.3"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="18">
                            <!-- Alev ikonu -->
                            <Border Grid.Column="0" WidthRequest="72" HeightRequest="72"
                                    BackgroundColor="#22FFFFFF" Stroke="#33FFFFFF" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 22">
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="0">
                                    <Label Text="🔥" FontSize="34" HorizontalOptions="Center"/>
                                    <Label Text="{Binding Profile.StreakDays}" FontSize="16" FontAttributes="Bold"
                                           TextColor="White" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <!-- Mesaj -->
                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                <Label Text="{Binding StreakMessage}" FontSize="17" FontAttributes="Bold"
                                       TextColor="White" LineBreakMode="WordWrap"/>
                                <Label Text="{Binding DailyGoal.CompletionText, StringFormat='Bugün: {0} görev tamamlandı'}"
                                       FontSize="13" TextColor="#DDFFFFFF"/>
                                <ProgressBar Progress="{Binding DailyGoal.ProgressRatio}"
                                             ProgressColor="{StaticResource BrandMint}"
                                             BackgroundColor="#33FFFFFF" HeightRequest="6"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- Görev listesi başlık -->
                    <Label Text="bugünün görevleri" Style="{StaticResource SectionLabel}"/>

                    <!-- Görev kartları -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding DailyGoal.Quests}" Spacing="12">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:DailyQuestInfo">
                                <controls:TappableBorder
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.GoToQuestGameCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource SurfaceWhite}"
                                    Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                                    StrokeShape="RoundRectangle 20" Padding="16,14">
                                    <controls:TappableBorder.Shadow>
                                        <Shadow Brush="#10000000" Offset="0,3" Radius="8" Opacity="0.10"/>
                                    </controls:TappableBorder.Shadow>

                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                        <!-- Emoji rozeti -->
                                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48"
                                                Stroke="Transparent" StrokeShape="RoundRectangle 14">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#E6FBF7"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="#EEF0FF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Emoji}" FontSize="24"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Border>

                                        <!-- Görev bilgisi -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold"
                                                   TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation"/>
                                            <Label Text="{Binding Description}" FontSize="11"
                                                   TextColor="{StaticResource TextMuted}" LineBreakMode="WordWrap"/>
                                            <ProgressBar Progress="{Binding ProgressRatio}"
                                                         ProgressColor="{StaticResource BrandMint}"
                                                         BackgroundColor="{StaticResource BorderLight}"
                                                         HeightRequest="5"/>
                                        </VerticalStackLayout>

                                        <!-- Durum -->
                                        <Border Grid.Column="2" Padding="10,6" Stroke="Transparent"
                                                StrokeShape="RoundRectangle 10" VerticalOptions="Center">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#E6FBF7"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsCompleted}" Value="False">
                                                    <Setter Property="BackgroundColor" Value="#EEF0FF"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding StatusText}" FontSize="11" FontAttributes="Bold"
                                                   VerticalOptions="Center">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="TextColor" Value="{StaticResource BrandMint}"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding IsCompleted}" Value="False">
                                                        <Setter Property="TextColor" Value="{StaticResource BrandPurple}"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                    </Grid>
                                </controls:TappableBorder>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- Motivasyon notu -->
                    <Border BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 18" Padding="16,12">
                        <HorizontalStackLayout Spacing="12">
                            <Label Text="💡" FontSize="22" VerticalOptions="Center"/>
                            <Label Text="{Binding DailyGoal.RewardText}" FontSize="13"
                                   TextColor="{StaticResource TextMuted}" VerticalOptions="Center"
                                   LineBreakMode="WordWrap" HorizontalOptions="FillAndExpand"/>
                        </HorizontalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
