<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Settings.PreferencesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{AppThemeBinding Light=#F0F2FA, Dark=#0F172A}">

    <ContentPage.Resources>
        <Color x:Key="TextPrimary">#172033</Color>
        <Color x:Key="TextMuted">#6B7280</Color>
        <Color x:Key="SurfaceWhite">#FFFFFF</Color>
        <Color x:Key="BorderLight">#E8E8F0</Color>

        <Style x:Key="SectionLabel" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#6B7280, Dark=#AAB3C5}" />
            <Setter Property="CharacterSpacing" Value="0" />
            <Setter Property="TextTransform" Value="Uppercase" />
        </Style>

        <Style x:Key="SettingCard" TargetType="Border">
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#172033}" />
            <Setter Property="Stroke" Value="{AppThemeBinding Light=#E8E8F0, Dark=#2B364A}" />
            <Setter Property="StrokeThickness" Value="0.5" />
            <Setter Property="StrokeShape" Value="RoundRectangle 18" />
            <Setter Property="Padding" Value="16,14" />
        </Style>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,32,32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5148D4" Offset="0.0" />
                    <GradientStop Color="#4C44C6" Offset="0.5" />
                    <GradientStop Color="#2F7C9E" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="22,52,22,24" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                <controls:TappableBorder
                    Grid.Column="0"
                    Command="{Binding GoBackCommand}"
                    WidthRequest="40"
                    HeightRequest="40"
                    BackgroundColor="#22FFFFFF"
                    Stroke="#33FFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 13"
                    VerticalOptions="Center">
                    <Label Text="←" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                </controls:TappableBorder>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="Profil ve Tercihler" FontSize="24" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Ses, görünüm ve oyun deneyimi" FontSize="13" TextColor="#AAFFFFFF" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,22,18,28" Spacing="20">

                <VerticalStackLayout Spacing="10">
                    <Label Text="seslendirme" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource SettingCard}">
                        <VerticalStackLayout Spacing="14">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="Anlatıcı sesi" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" />
                                    <Label Text="İsimler ve sesli tahmin ipuçları için kullanılır" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#AAB3C5}" />
                                </VerticalStackLayout>
                                <controls:TappableBorder
                                    Grid.Column="1"
                                    Command="{Binding PreviewVoiceCommand}"
                                    BackgroundColor="{AppThemeBinding Light=#E0FFF4, Dark=#173D36}"
                                    Stroke="{AppThemeBinding Light=#BEEEDC, Dark=#2B6B5F}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 13"
                                    Padding="12,8"
                                    VerticalOptions="Center">
                                    <Label Text="Dene" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" />
                                </controls:TappableBorder>
                            </Grid>

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                <controls:TappableBorder
                                    Grid.Column="0"
                                    Command="{Binding SetVoiceCommand}"
                                    CommandParameter="female"
                                    BackgroundColor="{Binding FemaleVoiceBackground}"
                                    Stroke="{AppThemeBinding Light=#DAD6FF, Dark=#5A54A3}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12,12">
                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                        <Label Text="👧" FontSize="28" HorizontalTextAlignment="Center" />
                                        <Label Text="Kız sesi" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </controls:TappableBorder>

                                <controls:TappableBorder
                                    Grid.Column="1"
                                    Command="{Binding SetVoiceCommand}"
                                    CommandParameter="male"
                                    BackgroundColor="{Binding MaleVoiceBackground}"
                                    Stroke="{AppThemeBinding Light=#CBEAF7, Dark=#326A84}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="12,12">
                                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                        <Label Text="👦" FontSize="28" HorizontalTextAlignment="Center" />
                                        <Label Text="Erkek sesi" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </controls:TappableBorder>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="ses" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource SettingCard}">
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="🔊" FontSize="24" VerticalOptions="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Genel ses seviyesi" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" />
                                    <Label Text="Konuşma ve oyun sesleri" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#AAB3C5}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding VolumeText}" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#5148D4, Dark=#A9C7FF}" VerticalOptions="Center" />
                            </Grid>
                            <Slider
                                Minimum="0"
                                Maximum="1"
                                Value="{Binding MasterVolume}"
                                ThumbColor="{AppThemeBinding Light=#6C62F5, Dark=#A9C7FF}"
                                MinimumTrackColor="{AppThemeBinding Light=#6C62F5, Dark=#A9C7FF}"
                                MaximumTrackColor="{AppThemeBinding Light=#EDE8FF, Dark=#2B364A}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource SettingCard}">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Label Grid.Column="0" Text="✨" FontSize="24" VerticalOptions="Center" />
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="Oyun efektleri" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" />
                                <Label Text="Doğru, yanlış ve başarı sesleri" FontSize="12" TextColor="{AppThemeBinding Light=#6B7280, Dark=#AAB3C5}" />
                            </VerticalStackLayout>
                            <Switch Grid.Column="2" IsToggled="{Binding EffectsEnabled}" ThumbColor="{AppThemeBinding Light=#6C62F5, Dark=#EAF2FF}" OnColor="{AppThemeBinding Light=#EDE8FF, Dark=#3A4A6A}" VerticalOptions="Center" />
                        </Grid>
                    </Border>

                    <controls:TappableBorder
                        Command="{Binding PreviewEffectCommand}"
                        BackgroundColor="{AppThemeBinding Light=#FFF8E7, Dark=#3E3320}"
                        Stroke="{AppThemeBinding Light=#F2DFA9, Dark=#7B6330}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 16"
                        Padding="16,12">
                        <Grid ColumnDefinitions="Auto,*">
                            <Label Grid.Column="0" Text="▶" FontSize="18" TextColor="{AppThemeBinding Light=#8A6B18, Dark=#FFD978}" VerticalOptions="Center" />
                            <Label Grid.Column="1" Text="Efekt sesini dene" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" VerticalOptions="Center" Margin="10,0,0,0" />
                        </Grid>
                    </controls:TappableBorder>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="10">
                    <Label Text="görünüm" Style="{StaticResource SectionLabel}" />
                    <Border Style="{StaticResource SettingCard}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="Tema" FontSize="15" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" />
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                <controls:TappableBorder
                                    Grid.Column="0"
                                    Command="{Binding SetThemeCommand}"
                                    CommandParameter="system"
                                    BackgroundColor="{Binding SystemThemeBackground}"
                                    Stroke="{AppThemeBinding Light=#DAD6FF, Dark=#5A54A3}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="8,10">
                                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                        <Label Text="📱" FontSize="22" HorizontalTextAlignment="Center" />
                                        <Label Text="Sistem" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </controls:TappableBorder>

                                <controls:TappableBorder
                                    Grid.Column="1"
                                    Command="{Binding SetThemeCommand}"
                                    CommandParameter="light"
                                    BackgroundColor="{Binding LightThemeBackground}"
                                    Stroke="{AppThemeBinding Light=#F2DFA9, Dark=#7B6330}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="8,10">
                                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                        <Label Text="☀" FontSize="22" HorizontalTextAlignment="Center" />
                                        <Label Text="Açık" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </controls:TappableBorder>

                                <controls:TappableBorder
                                    Grid.Column="2"
                                    Command="{Binding SetThemeCommand}"
                                    CommandParameter="dark"
                                    BackgroundColor="{Binding DarkThemeBackground}"
                                    Stroke="{AppThemeBinding Light=#D8DEE8, Dark=#4A5568}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 14"
                                    Padding="8,10">
                                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                                        <Label Text="🌙" FontSize="22" HorizontalTextAlignment="Center" />
                                        <Label Text="Koyu" FontSize="12" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#172033, Dark=#F8FAFC}" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </controls:TappableBorder>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <controls:BottomTabBar Grid.Row="2" IsProfileActive="True" />

    </Grid>
</views:AnimatedPage>
