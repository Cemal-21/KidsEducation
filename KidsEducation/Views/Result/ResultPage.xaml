<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Result.ResultPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource AppBackground}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ══ Gradient Header ══ -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 0,0,32,32">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#5148D4" Offset="0.0"/>
                            <GradientStop Color="#3A86FF" Offset="0.5"/>
                            <GradientStop Color="#21C7A8" Offset="1.0"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Padding="24,52,24,32" Spacing="12" HorizontalOptions="Center">

                        <!-- Stars emoji büyük -->
                        <Border BackgroundColor="#28FFFFFF" Stroke="#40FFFFFF" StrokeThickness="1"
                                StrokeShape="RoundRectangle 28" Padding="20,14" HorizontalOptions="Center">
                            <Label Text="{Binding StarsEmoji}" FontSize="52"
                                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </Border>

                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="{Binding StarsText}" FontSize="26" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                            <Label Text="Harika bir oyun oynadın! 🎉" FontSize="13"
                                   TextColor="#DDFFFFFF" HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Padding="18,20,18,32" Spacing="16">

                    <!-- ── Skor kartları 4'lü ── -->
                    <Border BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 24" Padding="16,16">
                        <Border.Shadow>
                            <Shadow Brush="#12000000" Offset="0,6" Radius="16" Opacity="0.14"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">

                            <!-- Yıldız -->
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                                <Border BackgroundColor="#FFF4D8" Stroke="#FFE1A3" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16" Padding="0" WidthRequest="52" HeightRequest="52">
                                    <Label Text="⭐" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding Stars}" FontSize="22" FontAttributes="Bold"
                                       TextColor="#C98600" HorizontalOptions="Center"/>
                                <Label Text="Yıldız" FontSize="10" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Doğru -->
                            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                                <Border BackgroundColor="#E6FFF5" Stroke="#B2F0D8" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16" Padding="0" WidthRequest="52" HeightRequest="52">
                                    <Label Text="✅" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource Success}" HorizontalOptions="Center">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding CorrectCount}"/>
                                            <Span Text="/" TextColor="{StaticResource TextMuted}" FontSize="14"/>
                                            <Span Text="{Binding TotalRounds}" TextColor="{StaticResource TextMuted}" FontSize="14"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Text="Doğru" FontSize="10" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Yanlış -->
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                                <Border BackgroundColor="#FFF0F0" Stroke="#FFD0D0" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16" Padding="0" WidthRequest="52" HeightRequest="52">
                                    <Label Text="❌" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding WrongCount}" FontSize="22" FontAttributes="Bold"
                                       TextColor="#E03030" HorizontalOptions="Center"/>
                                <Label Text="Yanlış" FontSize="10" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                            <!-- Puan -->
                            <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                                <Border BackgroundColor="#F0EEFF" Stroke="#D8D0FF" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 16" Padding="0" WidthRequest="52" HeightRequest="52">
                                    <Label Text="🏆" FontSize="26" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Text="{Binding Score}" FontSize="22" FontAttributes="Bold"
                                       TextColor="{StaticResource BrandPurple}" HorizontalOptions="Center"/>
                                <Label Text="Puan" FontSize="10" TextColor="{StaticResource TextMuted}"
                                       HorizontalOptions="Center"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>

                    <!-- Seviye ilerlemesi -->
                    <Border BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="16,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,4" Radius="12" Opacity="0.12"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                                    BackgroundColor="#FFF4D8" Stroke="#FFE1A3"
                                    StrokeThickness="1" StrokeShape="RoundRectangle 14">
                                <Label Text="🏅" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                                <Label Text="{Binding LevelText}" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                                <Label Text="{Binding LevelTitle}" FontSize="11"
                                       TextColor="{StaticResource TextMuted}" />
                                <ProgressBar Progress="{Binding LevelProgress}"
                                             ProgressColor="#F59E0B"
                                             BackgroundColor="#FEF3C7"
                                             HeightRequest="5"/>
                            </VerticalStackLayout>
                            <Label Grid.Column="2" Text="{Binding LevelProgressText}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="#92400E" VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- ── Günlük görev ── -->
                    <Border BackgroundColor="{StaticResource SurfaceWhite}"
                            Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                            StrokeShape="RoundRectangle 20" Padding="16,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,4" Radius="12" Opacity="0.12"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="12">
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                        BackgroundColor="#F1EEFF" Stroke="#DCD6FF" StrokeThickness="1"
                                        StrokeShape="RoundRectangle 14">
                                    <Label Text="🎯" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding DailyGoal.HeadlineText}" FontSize="14"
                                           FontAttributes="Bold" TextColor="{StaticResource TextPrimary}"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding DailyGoal.RewardText}" FontSize="11"
                                           TextColor="{StaticResource TextMuted}" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                                <Border Grid.Column="2" BackgroundColor="#F1EEFF" Stroke="#DCD6FF"
                                        StrokeThickness="1" StrokeShape="RoundRectangle 10"
                                        Padding="8,4" VerticalOptions="Center">
                                    <Label Text="{Binding DailyGoal.CompletionText}" FontSize="12"
                                           FontAttributes="Bold" TextColor="{StaticResource BrandPurple}"/>
                                </Border>
                            </Grid>

                            <VerticalStackLayout Spacing="7"
                                                 BindableLayout.ItemsSource="{Binding DailyGoal.Quests}">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="models:DailyQuestInfo">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Label Grid.Column="0" Text="{Binding Emoji}"
                                                   FontSize="16" VerticalOptions="Center"/>
                                            <Label Grid.Column="1" Text="{Binding Title}" FontSize="12"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   LineBreakMode="TailTruncation" VerticalOptions="Center"/>
                                            <Label Grid.Column="2" Text="{Binding StatusText}" FontSize="11"
                                                   FontAttributes="Bold" TextColor="{StaticResource TextMuted}"
                                                   VerticalOptions="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Modül sertifikası -->
                    <Border IsVisible="{Binding ShowModuleCertificate}"
                            BackgroundColor="#ECFDF5"
                            Stroke="#A7F3D0" StrokeThickness="1.5"
                            StrokeShape="RoundRectangle 20" Padding="16,14">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44"
                                    BackgroundColor="#D1FAE5" Stroke="Transparent"
                                    StrokeShape="RoundRectangle 14">
                                <Label Text="🎓" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                <Label Text="Modül Sertifikası" FontSize="14" FontAttributes="Bold"
                                       TextColor="#047857"/>
                                <Label Text="{Binding ModuleCertificateText}" FontSize="12"
                                       TextColor="#065F46"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ── Sertifika (sadece 3 yıldızda) ── -->
                    <Border IsVisible="{Binding ShowCertificate}"
                            Stroke="#FFD700" StrokeThickness="2"
                            StrokeShape="RoundRectangle 24" Padding="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FFFBEB" Offset="0"/>
                                <GradientStop Color="#FEF3C7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="#33FFD700" Offset="0,4" Radius="16" Opacity="0.3"/>
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="10" Padding="20,18" HorizontalOptions="Center">
                            <Label Text="🏅" FontSize="44" HorizontalOptions="Center" />
                            <Label Text="Tebrikler!" FontSize="22" FontAttributes="Bold"
                                   TextColor="#92400E" HorizontalOptions="Center" />
                            <Label FontSize="14" TextColor="#78350F" HorizontalOptions="Center"
                                   HorizontalTextAlignment="Center">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding CertificateProfileName}" FontAttributes="Bold" />
                                        <Span Text=", " />
                                        <Span Text="{Binding CertificateCategoryName}" FontAttributes="Bold" />
                                        <Span Text=" kategorisini mükemmel tamamladın!" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Text="⭐ ⭐ ⭐  Mükemmel Skor!" FontSize="16" FontAttributes="Bold"
                                   TextColor="#D97706" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- ── Aksiyon butonları ── -->
                    <controls:TappableBorder
                        Command="{Binding PlayAgainCommand}"
                        StrokeShape="RoundRectangle 20" Stroke="Transparent" Padding="0,16">
                        <controls:TappableBorder.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#5148D4" Offset="0.0"/>
                                <GradientStop Color="#3A86FF" Offset="1.0"/>
                            </LinearGradientBrush>
                        </controls:TappableBorder.Background>
                        <controls:TappableBorder.Shadow>
                            <Shadow Brush="#445148D4" Offset="0,6" Radius="14" Opacity="0.3"/>
                        </controls:TappableBorder.Shadow>
                        <Label Text="🔄  Tekrar Oyna" FontSize="17" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center"/>
                    </controls:TappableBorder>

                    <!-- Paylaş butonu -->
                    <controls:TappableBorder
                        Command="{Binding ShareResultCommand}"
                        BackgroundColor="#F4F3FF"
                        Stroke="#C7CEFF" StrokeThickness="1.5"
                        StrokeShape="RoundRectangle 20" Padding="0,16">
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                            <Label Text="📤" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Sonucu Paylaş" FontSize="17" FontAttributes="Bold"
                                   TextColor="#5148D4" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </controls:TappableBorder>

                    <controls:TappableBorder
                        Command="{Binding GoHomeCommand}"
                        BackgroundColor="{StaticResource SurfaceWhite}"
                        Stroke="{StaticResource BorderLight}" StrokeThickness="1"
                        StrokeShape="RoundRectangle 20" Padding="0,16">
                        <Label Text="🏠  Ana Menü" FontSize="17" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center"/>
                    </controls:TappableBorder>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <controls:CelebrationOverlay x:Name="Celebration" Dismissed="OnCelebrationDismissed"/>
    </Grid>
</views:AnimatedPage>
