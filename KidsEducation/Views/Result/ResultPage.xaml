<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Result.ResultPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="{StaticResource PlaygroundBackground}">

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="24,54,24,34" Spacing="18" VerticalOptions="Center">

                <Border
                    BackgroundColor="{StaticResource SurfaceWhite}"
                    Stroke="#FFE0BD"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 30"
                    Padding="22,24">
                    <Border.Shadow>
                        <Shadow Brush="#18000000" Offset="0,12" Radius="26" Opacity="0.2" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <Border BackgroundColor="#FFF4D8" Stroke="#FFE2A7" StrokeThickness="1" StrokeShape="RoundRectangle 24" Padding="16,12" HorizontalOptions="Center">
                            <Label Text="{Binding StarsEmoji}" FontSize="58" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </Border>

                        <VerticalStackLayout Spacing="5">
                            <Label Text="{Binding StarsText}" FontSize="29" FontFamily="OpenSansSemibold" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                            <Label Text="Bir tur daha oynarsan yeni yıldızlara çok yakınsın." FontSize="14" TextColor="{StaticResource TextMuted}" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,4,0,0">
                            <Border Grid.Column="0" BackgroundColor="#FFF4D8" Stroke="#FFE1A3" StrokeThickness="1" StrokeShape="RoundRectangle 18" Padding="10,13">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="⭐" FontSize="27" HorizontalOptions="Center" />
                                    <Label Text="{Binding Stars}" FontSize="25" FontAttributes="Bold" TextColor="#C98600" HorizontalOptions="Center" />
                                    <Label Text="Yıldız" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1" BackgroundColor="#E9FFF8" Stroke="#C8F4E8" StrokeThickness="1" StrokeShape="RoundRectangle 18" Padding="10,13">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="✅" FontSize="27" HorizontalOptions="Center" />
                                    <Label FontSize="25" FontAttributes="Bold" TextColor="{StaticResource Success}" HorizontalOptions="Center">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding CorrectCount}" />
                                                <Span Text="/" TextColor="{StaticResource TextMuted}" FontSize="17" />
                                                <Span Text="{Binding TotalRounds}" TextColor="{StaticResource TextMuted}" FontSize="17" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Text="Doğru" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="2" BackgroundColor="#FFF0F5" Stroke="#FFD5E2" StrokeThickness="1" StrokeShape="RoundRectangle 18" Padding="10,13">
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="🏆" FontSize="27" HorizontalOptions="Center" />
                                    <Label Text="{Binding Score}" FontSize="25" FontAttributes="Bold" TextColor="{StaticResource BrandCoral}" HorizontalOptions="Center" />
                                    <Label Text="Puan" FontSize="11" TextColor="{StaticResource TextMuted}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <Border
                    BackgroundColor="{StaticResource SurfaceWhite}"
                    Stroke="#E8E8F0"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    Padding="14">
                    <VerticalStackLayout Spacing="11">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                            <Border Grid.Column="0" WidthRequest="42" HeightRequest="42" BackgroundColor="#F1EEFF" Stroke="#DCD6FF" StrokeThickness="1" StrokeShape="RoundRectangle 15">
                                <Label Text="🎯" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding DailyGoal.HeadlineText}" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DailyGoal.RewardText}" FontSize="11" TextColor="{StaticResource TextMuted}" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2" Text="{Binding DailyGoal.CompletionText}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource BrandPurple}" VerticalOptions="Center" />
                        </Grid>

                        <VerticalStackLayout Spacing="8" BindableLayout.ItemsSource="{Binding DailyGoal.Quests}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="models:DailyQuestInfo">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="9">
                                        <Label Grid.Column="0" Text="{Binding Emoji}" FontSize="18" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="{Binding Title}" FontSize="12" TextColor="{StaticResource TextPrimary}" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                        <Label Grid.Column="2" Text="{Binding StatusText}" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource TextMuted}" VerticalOptions="Center" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <controls:TappableBorder
                    Command="{Binding PlayAgainCommand}"
                    BackgroundColor="{StaticResource BrandCoral}"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 20"
                    Padding="0,16">
                    <controls:TappableBorder.Shadow>
                        <Shadow Brush="#44FF6B8A" Offset="0,8" Radius="16" Opacity="0.3" />
                    </controls:TappableBorder.Shadow>
                    <Label Text="🔄  Tekrar Oyna" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" />
                </controls:TappableBorder>

                <controls:TappableBorder
                    Command="{Binding GoHomeCommand}"
                    BackgroundColor="{StaticResource SurfaceWhite}"
                    Stroke="#FFE0BD"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="0,16">
                    <Label Text="🏠  Ana Menü" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                </controls:TappableBorder>

            </VerticalStackLayout>
        </ScrollView>

        <controls:CelebrationOverlay
            x:Name="Celebration"
            Dismissed="OnCelebrationDismissed" />
    </Grid>
</views:AnimatedPage>
