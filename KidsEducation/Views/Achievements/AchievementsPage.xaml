<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Achievements.AchievementsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:KidsEducation.ViewModels.Achievements"
    xmlns:models="clr-namespace:KidsEducation.Models"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:converters="clr-namespace:KidsEducation.Converters"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F0F2FA">

    <ContentPage.Resources>
        <Color x:Key="TextPrimary">#172033</Color>
        <Color x:Key="TextMuted">#6B7280</Color>
        <Color x:Key="BrandPurple">#4C44C6</Color>
        <Color x:Key="BrandPurpleLight">#6C62F5</Color>
        <Color x:Key="SurfaceWhite">#FFFFFF</Color>
        <Color x:Key="BorderLight">#E8E8F0</Color>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        <converters:BadgeFooterColorConverter x:Key="BadgeFooterColorConverter" />
        <converters:BadgeProgressConverter x:Key="BadgeProgressConverter" />
        <converters:BoolToFullOpacityConverter x:Key="BoolToFullOpacityConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ── Header ── -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,32,32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#5148D4" Offset="0.0" />
                    <GradientStop Color="#4C44C6" Offset="0.5" />
                    <GradientStop Color="#3A6BD4" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid Padding="22,52,22,24" RowDefinitions="Auto,Auto" RowSpacing="18">

                <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <controls:TappableBorder
                        Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        WidthRequest="40" HeightRequest="40"
                        BackgroundColor="#22FFFFFF"
                        Stroke="#33FFFFFF" StrokeThickness="1"
                        StrokeShape="RoundRectangle 13"
                        VerticalOptions="Center">
                        <Label Text="←" FontSize="20" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                    </controls:TappableBorder>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Başarımlar" FontSize="24" FontAttributes="Bold" TextColor="White" />
                        <Label Text="{Binding ActiveProfile.Name, StringFormat='{0} rozetleri'}" FontSize="13" TextColor="#AAFFFFFF" />
                    </VerticalStackLayout>
                </Grid>

                <Border Grid.Row="1" BackgroundColor="#20FFFFFF" Stroke="#30FFFFFF" StrokeThickness="1" StrokeShape="RoundRectangle 16" Padding="16,12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <VerticalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="{Binding ProgressText, StringFormat='🏅 {0} rozet kazanıldı'}" FontSize="14" FontAttributes="Bold" TextColor="White" />
                            <Border HeightRequest="6" BackgroundColor="#30FFFFFF" Stroke="Transparent" StrokeShape="RoundRectangle 10">
                                <Border HorizontalOptions="Start" HeightRequest="6" WidthRequest="{Binding EarnedCount, Converter={StaticResource BadgeProgressConverter}}" BackgroundColor="#FFD66B" Stroke="Transparent" StrokeShape="RoundRectangle 10" />
                            </Border>
                        </VerticalStackLayout>
                        <Label Grid.Column="1" Text="{Binding EarnedCount}" FontSize="32" FontAttributes="Bold" TextColor="#FFD66B" VerticalOptions="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ── Rozet Listesi ── -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,20,18,16" Spacing="12">
                <CollectionView ItemsSource="{Binding Badges}">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="12" VerticalItemSpacing="12" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Badge">
                            <Border BackgroundColor="{StaticResource SurfaceWhite}" Stroke="{StaticResource BorderLight}" StrokeThickness="0.5" StrokeShape="RoundRectangle 20" Padding="0">
                                <Border.Shadow>
                                    <Shadow Brush="#0A000000" Offset="0,4" Radius="10" Opacity="0.1" />
                                </Border.Shadow>
                                <Grid RowDefinitions="*,Auto">

                                    <!-- Rozet içeriği -->
                                    <VerticalStackLayout Grid.Row="0" Spacing="8" Padding="14,16,14,12" HorizontalOptions="Center">
                                        <Grid HorizontalOptions="Center">
                                            <Label
                                                Text="{Binding Emoji}"
                                                FontSize="44"
                                                HorizontalOptions="Center"
                                                Opacity="{Binding IsEarned, Converter={StaticResource BoolToOpacityConverter}}" />
                                            <Border
                                                IsVisible="{Binding IsLocked}"
                                                BackgroundColor="#CCFFFFFF"
                                                Stroke="Transparent"
                                                StrokeShape="RoundRectangle 50"
                                                WidthRequest="26" HeightRequest="26"
                                                HorizontalOptions="End" VerticalOptions="End">
                                                <Label Text="🔒" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                        <Label
                                            Text="{Binding NameTr}"
                                            FontSize="13" FontAttributes="Bold"
                                            TextColor="{StaticResource TextPrimary}"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="WordWrap" />
                                        <!-- Açıklama sadece üstte, bir kez -->
                                        <Label
                                            Text="{Binding DescriptionTr}"
                                            FontSize="11"
                                            TextColor="{StaticResource TextMuted}"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="WordWrap" />
                                    </VerticalStackLayout>

                                    <!-- Alt şerit -->
                                    <Border
                                        Grid.Row="1"
                                        StrokeShape="RoundRectangle 0,0,20,20"
                                        Stroke="Transparent"
                                        Padding="10,8"
                                        BackgroundColor="{Binding IsEarned, Converter={StaticResource BadgeFooterColorConverter}}">
                                        <Grid>
                                            <!-- Kazanıldı: tarih göster -->
                                            <HorizontalStackLayout
                                                Spacing="4"
                                                HorizontalOptions="Center"
                                                IsVisible="{Binding IsEarned}">
                                                <Label Text="✅" FontSize="11" VerticalOptions="Center" />
                                                <Label
                                                    Text="{Binding EarnedDateText}"
                                                    FontSize="10"
                                                    TextColor="#1D9E75"
                                                    FontAttributes="Bold"
                                                    VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <!-- Kilitli: sabit metin, açıklama tekrar etmez -->
                                            <Label
                                                Text="Henüz kazanılmadı"
                                                FontSize="10"
                                                TextColor="#6B7280"
                                                HorizontalTextAlignment="Center"
                                                IsVisible="{Binding IsLocked}" />
                                        </Grid>
                                    </Border>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <!-- ── TAB BAR ── -->
        <controls:BottomTabBar Grid.Row="2" IsAchievementsActive="True" />

    </Grid>
</views:AnimatedPage>
