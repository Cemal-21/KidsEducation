<?xml version="1.0" encoding="utf-8" ?>
<views:AnimatedPage
    x:Class="KidsEducation.Views.Learning.ItemDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:KidsEducation.Views.Controls"
    xmlns:views="clr-namespace:KidsEducation.Views"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F0F2FA">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Border Grid.Row="0" Stroke="Transparent" StrokeShape="RoundRectangle 0,0,32,32">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{Binding CategoryColorHex}"  Offset="0.0" />
                    <GradientStop Color="{Binding CategoryColorHex2}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <BoxView Color="#2E172033" />

                <Grid Padding="22,52,22,22" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">

                <controls:TappableBorder
                    Grid.Column="0"
                    Command="{Binding GoBackCommand}"
                    WidthRequest="44" HeightRequest="44"
                    BackgroundColor="#F8FFFFFF"
                    Stroke="#55FFFFFF" StrokeThickness="1"
                    StrokeShape="RoundRectangle 15"
                    VerticalOptions="Center">
                    <Label Text="←" FontSize="22" TextColor="#172033" HorizontalOptions="Center" VerticalOptions="Center" />
                </controls:TappableBorder>

                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                    <Label Text="{Binding Item.NameTr}" FontSize="26" FontAttributes="Bold" TextColor="White" LineBreakMode="TailTruncation" />
                    <Label Text="{Binding Item.NameEn}" FontSize="14" TextColor="#F0FFFFFF" />
                </VerticalStackLayout>

                <!-- Kategori emoji -->
                <Border
                    Grid.Column="2"
                    WidthRequest="50" HeightRequest="50"
                    BackgroundColor="#F8FFFFFF"
                    Stroke="#55FFFFFF" StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    VerticalOptions="Center">
                    <Image Source="{Binding CategoryImage}" WidthRequest="40" HeightRequest="40" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- İÇERİK -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="18,20,18,34" Spacing="16">

                <!-- Görsel kart -->
                <Border
                    BackgroundColor="White"
                    Stroke="#EEF1F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 28"
                    Padding="24">
                    <Border.Shadow>
                        <Shadow Brush="#18000000" Offset="0,8" Radius="20" Opacity="0.15" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <Image
                            Source="{Binding Item.ImagePath}"
                            HeightRequest="200"
                            Aspect="AspectFit"
                            HorizontalOptions="Center" />

                        <!-- İsim + Ses butonu -->
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="4" VerticalOptions="Center">
                                <Label Text="{Binding Item.NameTr}" FontSize="28" FontAttributes="Bold" TextColor="#172033" />
                                <Label Text="{Binding Item.NameEn}" FontSize="16" TextColor="#6B7280" />
                            </VerticalStackLayout>

                            <!-- İsim ses butonu -->
                            <controls:TappableBorder
                                Grid.Column="1"
                                Command="{Binding SpeakCommand}"
                                WidthRequest="52" HeightRequest="52"
                                BackgroundColor="#EDE9FF"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 16"
                                VerticalOptions="Center">
                                <Image Source="ui_mic_3d.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                            </controls:TappableBorder>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Eğlenceli bilgi kartı -->
                <Border
                    BackgroundColor="#FFF8E7"
                    Stroke="#FFE082"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="16,14">
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                        <Image Grid.Column="0" Source="ui_star_3d.png" WidthRequest="32" HeightRequest="32" Aspect="AspectFit" VerticalOptions="Center" />
                        <Label
                            Grid.Column="1"
                            Text="{Binding Item.FunFact}"
                            FontSize="15"
                            TextColor="#172033"
                            LineHeight="1.4"
                            VerticalOptions="Center" />
                        <!-- FunFact ses butonu -->
                        <!--<controls:TappableBorder
                            Grid.Column="2"
                            Command="{Binding SpeakFunFactCommand}"
                            WidthRequest="40" HeightRequest="40"
                            BackgroundColor="#FFE082"
                            Stroke="Transparent"
                            StrokeShape="RoundRectangle 12"
                            VerticalOptions="Center">
                            <Image Source="ui_mic_3d.png" WidthRequest="24" HeightRequest="24" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                        </controls:TappableBorder>-->
                    </Grid>
                </Border>

                <!-- Açıklama kartı -->
                <Border
                    BackgroundColor="White"
                    Stroke="#EEF1F7"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 20"
                    Padding="16,14">
                    <Border.Shadow>
                        <Shadow Brush="#0A000000" Offset="0,4" Radius="10" Opacity="0.1" />
                    </Border.Shadow>
                    <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                            <HorizontalStackLayout Grid.Column="0" Spacing="6">
                                <Image Source="ui_tales_3d.png" WidthRequest="22" HeightRequest="22" Aspect="AspectFit" />
                                <Label Text="AÇIKLAMA" FontSize="13" FontAttributes="Bold" TextColor="#6B7280" TextTransform="Uppercase" CharacterSpacing="1" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <!-- Açıklama ses butonu -->
                            <controls:TappableBorder
                                Grid.Column="1"
                                Command="{Binding SpeakDescriptionCommand}"
                                WidthRequest="36" HeightRequest="36"
                                BackgroundColor="#EDE9FF"
                                Stroke="Transparent"
                                StrokeShape="RoundRectangle 10">
                                <Image Source="ui_mic_3d.png" WidthRequest="22" HeightRequest="22" Aspect="AspectFit" HorizontalOptions="Center" VerticalOptions="Center" />
                            </controls:TappableBorder>
                        </Grid>
                        <Label
                            Grid.Row="1"
                            Text="{Binding Item.DescriptionTr}"
                            FontSize="15"
                            TextColor="#172033"
                            LineHeight="1.5" />
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</views:AnimatedPage>
