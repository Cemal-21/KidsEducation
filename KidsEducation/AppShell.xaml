<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="KidsEducation.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:home="clr-namespace:KidsEducation.Views.Home"
    xmlns:achievements="clr-namespace:KidsEducation.Views.Achievements"
    xmlns:progress="clr-namespace:KidsEducation.Views.Progress"
    xmlns:profile="clr-namespace:KidsEducation.Views.Profile"
    xmlns:parental="clr-namespace:KidsEducation.Views.Parental"
    xmlns:onboarding="clr-namespace:KidsEducation.Views.Onboarding"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <ShellContent Route="onboarding"       ContentTemplate="{DataTemplate onboarding:OnboardingPage}" />
    <ShellContent Route="profileselection" ContentTemplate="{DataTemplate home:ProfileSelectionPage}" />
    <ShellContent Route="home"             ContentTemplate="{DataTemplate home:HomePage}" />
    <ShellContent Route="achievements"     ContentTemplate="{DataTemplate achievements:AchievementsPage}" />
    <ShellContent Route="progress"         ContentTemplate="{DataTemplate progress:ProgressPage}" />
    <ShellContent Route="profile"          ContentTemplate="{DataTemplate profile:ProfilePage}" />
    <ShellContent Route="parental"         ContentTemplate="{DataTemplate parental:ParentalPage}" />

</Shell>
